{
  "name": "cretop-data-reader-desktop",
  "version": "1.4.1",
  "private": true,
  "description": "Modern Electron desktop UI for Cretop Data Reader",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/lynchlee1/CretopDataReader.git"
  },
  "scripts": {
    "desktop": "electron .",
    "desktop:dev": "electron . --dev",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --dir"
  },
  "build": {
    "appId": "com.cretopdatareader.desktop",
    "productName": "Cretop Data Reader",
    "directories": {
      "output": "dist"
    },
    "artifactName": "Cretop-Data-Reader-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "lynchlee1",
        "repo": "CretopDataReader"
      }
    ],
    "asar": true,
    "files": [
      "electron/**/*",
      "package.json",
      "!**/AGENTS.md",
      "!**/README.md",
      "!**/docs/**",
      "!**/tests/**",
      "!**/.pytest_cache/**",
      "!**/.mypy_cache/**",
      "!**/.ruff_cache/**",
      "!**/.chrome-profile/**",
      "!**/network-logs/**",
      "!**/output/**",
      "!**/logs/**",
      "!**/data/**",
      "!**/input/**",
      "!**/exports/**",
      "!**/downloads/**",
      "!**/*.xlsx",
      "!**/*.xlsm",
      "!**/*.xls",
      "!**/*.csv",
      "!**/ms-playwright/**",
      "!**/.local-browsers/**",
      "!**/chromium*/**",
      "!**/chrome-*/**"
    ],
    "extraResources": [
      {
        "from": "pyproject.toml",
        "to": "pyproject.toml"
      },
      {
        "from": "src/cretop_data_reader",
        "to": "src/cretop_data_reader",
        "filter": [
          "**/*.py"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
